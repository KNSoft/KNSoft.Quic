<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/01/nuspec.xsd">
  <metadata>
    <id>KNSoft.Quic</id>
    <version>1.0.0-beta</version>
    <title>KNSoft.Quic</title>
    <authors>KNSoft</authors>
    <projectUrl>https://github.com/KNSoft/KNSoft.Quic</projectUrl>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <description>KNSoft.Quic</description>
    <tags>native Windows Utility Quic MsQuic Runtime</tags>
    <repository type="git" url="https://github.com/KNSoft/KNSoft.Quic" />
  </metadata>
  <files>
    <file src="README.md" target="" />
    <file src="KNSoft.Quic.targets" target="build\" />

    <file src="KNSoft.Quic.h" target="build\Include\" />
    <file src="msquic\src\inc\msquic.h" target="build\Include\msquic\src\inc\" />
    <file src="msquic\src\inc\msquic_winuser.h" target="build\Include\msquic\src\inc\" />
    <file src="msquic\src\core\api.h" target="build\Include\msquic\src\core\" />

    <file src="OutDir\**\*.lib" exclude="OutDir\x86\**" target="build\Lib\" />
    <file src="OutDir\**\*.pdb" exclude="OutDir\x86\**" target="build\Lib\" />
    <file src="OutDir\**\*.pgd" exclude="OutDir\x86\**" target="build\Lib\" />
    <file src="OutDir\**\*PGO.json" exclude="OutDir\x86\**" target="build\Lib\" />
    <file src="OutDir\x86\**\*.lib" target="build\Lib\Win32\" />
    <file src="OutDir\x86\**\*.pdb" exclude="OutDir\x86\**\Demo.pdb" target="build\Lib\Win32\" />
    <file src="OutDir\x86\**\*.pgd" target="build\Lib\Win32\" />
    <file src="OutDir\x86\**\*PGO.json" target="build\Lib\Win32\" />
  </files>
</package>
